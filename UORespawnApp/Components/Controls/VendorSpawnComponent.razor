        /// <summary>
        /// Attempts to add an XML spawner at the current mouse position via backtick (`) key.
        /// </summary>
        private async Task TryAddXmlSpawnerAtMousePosition()
        {
            // Use the current mouse world coordinates (already tracked by OnMouseMove)
            await OnRequestAddXmlSpawner(mouseWorldX, mouseWorldY);
        }

        /// <summary>
        /// Attempts to delete the currently hovered XML spawner via DEL key.
        /// </summary>
        private async Task TryDeleteHoveredXmlSpawner()
        {
            try
            {
                // Get hovered XML spawner from JavaScript
                var result = await JS.InvokeAsync<string>("eval", "JSON.stringify(window.mapModule.getHoveredXmlSpawner())");
                if (string.IsNullOrEmpty(result) || result == "null")
            {
                // No spawner hovered, do nothing
                return;
            }

            // Parse the spawner data
            using var doc = System.Text.Json.JsonDocument.Parse(result);
            var root = doc.RootElement;

            var serial = root.TryGetProperty("serial", out var serialProp) ? serialProp.GetString() : null;
            var idx = root.TryGetProperty("idx", out var idxProp) ? idxProp.GetInt32() : -1;

            // If no idx in JSON, get the hovered index directly
            if (idx < 0)
            {
                idx = await JS.InvokeAsync<int>("eval", "window.mapModule.hoveredXmlSpawnerId ?? -1");
            }

            if (!string.IsNullOrEmpty(serial))
            {
                await OnRequestDeleteXmlSpawner(serial, idx);
            }
        }
        catch (Exception ex)
        {
            Logger.Error("Error getting hovered XML spawner for delete", ex);
        }
    }

    /// <summary>
    /// Called from JavaScript when user clicks delete button in XML spawner tooltip.
    /// Shows confirmation dialog before proceeding.
    /// </summary>
    [JSInvokable]
    public async Task OnRequestDeleteXmlSpawner(string serial, int idx)
    {
        if (string.IsNullOrEmpty(serial))
        {
            ToastService.ShowWarning("Cannot delete: Spawner has no serial ID");
            return;
        }

        if (!XmlSpawnerCommandService.CanWriteCommands())
        {
            ToastService.ShowWarning("Cannot delete: Server not linked. Link your server in Settings first.");
            return;
        }

        // Store pending delete info and show confirmation
        pendingDeleteSerial = serial;
        pendingDeleteIdx = idx;
        showDeleteConfirmation = true;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Called from JavaScript when user holds X + clicks on map to add XML spawner.
    /// Opens the add spawner modal with bestiary picker.
    /// </summary>
    [JSInvokable]
    public async Task OnRequestAddXmlSpawner(int worldX, int worldY)
    {
        if (!XmlSpawnerCommandService.CanWriteCommands())
        {
            ToastService.ShowWarning("Cannot add spawner: Server not linked. Link your server in Settings first.");
            return;
        }

        // Store coordinates and show add modal
        addXmlWorldX = worldX;
        addXmlWorldY = worldY;
        showAddXmlModal = true;
        await InvokeAsync(StateHasChanged);

        Logger.Info($"Opening Add XML Spawner modal at ({worldX}, {worldY})");
    }

    private async Task ConfirmDeleteXmlSpawner()
    {
        if (string.IsNullOrEmpty(pendingDeleteSerial))
        {
            showDeleteConfirmation = false;
            return;
        }

        // Check for existing pending command
        var pendingCmd = XmlSpawnerCommandService.GetPendingCommand(pendingDeleteSerial);
        if (pendingCmd != null)
        {
            ToastService.ShowWarning($"Cannot delete: Spawner already has pending {pendingCmd} command");
            showDeleteConfirmation = false;
            pendingDeleteSerial = null;
            pendingDeleteIdx = -1;
            StateHasChanged();
            return;
        }

        // Write delete command
        if (XmlSpawnerCommandService.WriteDeleteCommand(pendingDeleteSerial))
        {
            // Remove from local view
            await JS.InvokeVoidAsync("eval", $"window.mapModule.removeXmlSpawnerLocally({pendingDeleteIdx})");
            SpawnerListUtility.RemoveSpawnerLocally(pendingDeleteSerial);

            Logger.Info($"XML Spawner delete command sent: {pendingDeleteSerial}");
            ToastService.ShowWarning($"Delete command sent. Spawner will be removed when server restarts.");
        }
        else
        {
            ToastService.ShowWarning("Failed to write delete command");
        }

        // Clear state
        showDeleteConfirmation = false;
        pendingDeleteSerial = null;
        pendingDeleteIdx = -1;
        StateHasChanged();
    }

    private void CancelDeleteXmlSpawner()
    {
        showDeleteConfirmation = false;
        pendingDeleteSerial = null;
        pendingDeleteIdx = -1;
        StateHasChanged();
    }

    private void CancelAddXmlSpawner()
    {
        showAddXmlModal = false;
        addXmlWorldX = 0;
        addXmlWorldY = 0;
        StateHasChanged();
    }

    /// <summary>
    /// Attempts to edit the currently hovered XML spawner via Enter key.
    /// </summary>
    private async Task TryEditHoveredXmlSpawner()
    {
        try
        {
            // Get hovered XML spawner from JavaScript
            var result = await JS.InvokeAsync<string>("eval", "JSON.stringify(window.mapModule.getHoveredXmlSpawner())");
            if (string.IsNullOrEmpty(result) || result == "null")
            {
                // No spawner hovered, do nothing
                return;
            }

            // Parse the spawner data
            using var doc = System.Text.Json.JsonDocument.Parse(result);
            var root = doc.RootElement;

            var serial = root.TryGetProperty("serial", out var serialProp) ? serialProp.GetString() : null;

            if (string.IsNullOrEmpty(serial))
            {
                ToastService.ShowWarning("Cannot edit: Spawner has no serial ID");
                return;
            }

            if (!XmlSpawnerCommandService.CanWriteCommands())
            {
                ToastService.ShowWarning("Cannot edit: Server not linked. Link your server in Settings first.");
                return;
            }

            // Check for existing pending command
            var pendingCmd = XmlSpawnerCommandService.GetPendingCommand(serial);
            if (pendingCmd != null)
            {
                ToastService.ShowWarning($"Cannot edit: Spawner already has pending {pendingCmd} command");
                return;
            }

            // Get full spawner info from utility
            var spawner = SpawnerListUtility.GetSpawnerBySerial(serial);
            if (spawner == null)
            {
                ToastService.ShowWarning("Cannot edit: Spawner data not found");
                return;
            }

            // Populate edit modal state
            editXmlSerial = serial;
            editXmlWorldX = spawner.CenterX;
            editXmlWorldY = spawner.CenterY;
            editXmlHomeRange = spawner.Radius > 0 ? spawner.Radius : 20;
            editXmlMaxCount = spawner.MaxCount > 0 ? spawner.MaxCount : 10;
            editXmlSpawnNames = spawner.SpawnNames != null ? [.. spawner.SpawnNames] : [];

            // Show edit modal
            showEditXmlModal = true;
            await InvokeAsync(StateHasChanged);

            Logger.Info($"Opening Edit XML Spawner modal for {serial} at ({editXmlWorldX}, {editXmlWorldY})");
        }
        catch (Exception ex)
        {
            Logger.Error("Error getting hovered XML spawner for edit", ex);
        }
    }

    private void CancelEditXmlSpawner()
    {
        showEditXmlModal = false;
        editXmlSerial = string.Empty;
        editXmlWorldX = 0;
        editXmlWorldY = 0;
        editXmlHomeRange = 20;
        editXmlMaxCount = 10;
        editXmlSpawnNames = [];
        StateHasChanged();
    }

