    /// <summary>
    /// Opens the vendor modal in bulk mode - shows vendors common to ALL locations.
    /// Adding vendors will add to all locations; removing vendors will remove from all locations.
    /// </summary>
    private void OpenBulkAddModal(SignTypeGroup group)
    {
        currentSignType = group.SignType;
        currentIsHive = group.SignType == SignTypes.MetalPost;

        // Load vendors that are common to ALL locations (intersection)
        var commonVendors = GetCommonVendorsForSignType(group.SignType);
        originalBulkVendorList = new List<string>(commonVendors);
        currentVendorList = new List<string>(commonVendors);

        isBulkAddMode = true;
        showModal = true;
        StateHasChanged();
    }

    /// <summary>
    /// Gets vendors that exist in ALL locations of a sign type (intersection).
    /// Returns empty list if any location has no vendors or if locations have no common vendors.
    /// </summary>
    private List<string> GetCommonVendorsForSignType(SignTypes signType)
    {
        if (!Utility.VendorSpawns.TryGetValue(ViewService.CurrentMapId, out var vendors))
            return [];

        List<List<string>> allLocationVendors = [];

        if (signType == SignTypes.MetalPost)
        {
            var hives = HiveDataUtility.GetHivesForMap(ViewService.CurrentMapId);
            foreach (var hive in hives)
            {
                var entity = vendors.FirstOrDefault(v => 
                    v.Sign == SignTypes.MetalPost && 
                    v.Location.X == hive.X && 
                    v.Location.Y == hive.Y && 
                    v.Location.Z == hive.Z);
                allLocationVendors.Add(entity?.VendorList ?? []);
            }
        }
        else
        {
            var signs = SignDataUtility.GetSignsForMap(ViewService.CurrentMapId)
                .Where(s => s.SignType == signType)
                .ToList();

            foreach (var sign in signs)
            {
                var entity = vendors.FirstOrDefault(v => 
                    v.Sign == signType && 
                    v.Location.X == sign.X && 
                    v.Location.Y == sign.Y && 
                    v.Location.Z == sign.Z);
                allLocationVendors.Add(entity?.VendorList ?? []);
            }
        }

        if (allLocationVendors.Count == 0)
            return [];

        // Find intersection - vendors that exist in ALL locations
        var commonVendors = allLocationVendors[0].ToList();
        foreach (var locationVendors in allLocationVendors.Skip(1))
        {
            commonVendors = commonVendors.Intersect(locationVendors).ToList();
        }

        return commonVendors;
    }

    private void LoadVendorListForCurrentLocation()
    {
        if (Utility.VendorSpawns.TryGetValue(ViewService.CurrentMapId, out var vendors))
        {
            var vendorEntity = vendors.FirstOrDefault(v => 
                v.Sign == currentSignType && 
                v.Location.X == currentLocation.X && 
                v.Location.Y == currentLocation.Y && 
                v.Location.Z == currentLocation.Z);
            currentVendorList = vendorEntity != null 
                ? new List<string>(vendorEntity.VendorList) 
                : new List<string>();
        }
        else
        {
            currentVendorList = new List<string>();
        }
    }

    private void CloseModal()
    {
        showModal = false;
        isBulkAddMode = false;
        originalBulkVendorList = [];
        StateHasChanged();
    }

    private async Task SaveModal()
    {
        if (isBulkAddMode)
        {
            await SaveBulkAddModal();
            return;
        }

        var vendors = Utility.GetOrCreateVendorList(ViewService.CurrentMapId);

        // Remove existing vendor entity for this specific location
        vendors.RemoveAll(v => 
            v.Sign == currentSignType && 
            v.Location.X == currentLocation.X && 
            v.Location.Y == currentLocation.Y && 
            v.Location.Z == currentLocation.Z);

        // Create vendor entity for this specific location
        if (currentVendorList.Count > 0)
        {
            VendorEntity vendorEntity;
            if (currentIsHive)
            {
                vendorEntity = new VendorEntity(currentLocation);
            }
            else
            {
                vendorEntity = new VendorEntity(currentSignType, currentFacing, currentLocation);
            }

            vendorEntity.MapId = ViewService.CurrentMapId;
            vendorEntity.SetVendors(new List<string>(currentVendorList));
            vendors.Add(vendorEntity);
        }

        PathConstants.IsSpawnDataDirty = true;
        Utility.SaveVendorSpawnData();
        Logger.Info($"Saved {currentVendorList.Count} vendors for location ({currentLocation.X}, {currentLocation.Y}, {currentLocation.Z})");

        CloseModal();
        await RenderVendorMarkers();
        StateHasChanged();
    }

    /// <summary>
    /// Saves vendors in bulk mode - compares with original common vendors to determine additions and removals.
    /// Additions are added to all locations; removals are removed from all locations.
    /// </summary>
    private async Task SaveBulkAddModal()
    {
        var vendors = Utility.GetOrCreateVendorList(ViewService.CurrentMapId);

        // Calculate what was added vs removed compared to original common vendors
        var vendorsToAdd = currentVendorList.Except(originalBulkVendorList).ToList();
        var vendorsToRemove = originalBulkVendorList.Except(currentVendorList).ToList();

        if (vendorsToAdd.Count == 0 && vendorsToRemove.Count == 0)
        {
            CloseModal();
            return;
        }

        int locationsUpdated = 0;

        if (currentSignType == SignTypes.MetalPost)
        {
            var hives = HiveDataUtility.GetHivesForMap(ViewService.CurrentMapId);
            foreach (var hive in hives)
            {
                var location = new Point3D { X = hive.X, Y = hive.Y, Z = hive.Z };
                var existingEntity = vendors.FirstOrDefault(v => 
                    v.Sign == SignTypes.MetalPost && 
                    v.Location.X == location.X && 
                    v.Location.Y == location.Y && 
                    v.Location.Z == location.Z);

                if (existingEntity != null)
                {
                    // Remove vendors from all locations
                    foreach (var vendor in vendorsToRemove)
                    {
                        existingEntity.RemoveVendor(vendor);
                    }
                    // Add vendors to all locations
                    foreach (var vendor in vendorsToAdd)
                    {
                        existingEntity.AddVendor(vendor);
                    }
                    // Remove entity if no vendors left
                    if (existingEntity.VendorList.Count == 0)
                    {
                        vendors.Remove(existingEntity);
                    }
                }
                else if (vendorsToAdd.Count > 0)
                {
                    // Create new entity with the vendors to add
                    var newEntity = new VendorEntity(location)
                    {
                        MapId = ViewService.CurrentMapId
                    };
                    newEntity.SetVendors(new List<string>(vendorsToAdd));
                    vendors.Add(newEntity);
                }
                locationsUpdated++;
            }
        }
        else
        {
            var signs = SignDataUtility.GetSignsForMap(ViewService.CurrentMapId)
                .Where(s => s.SignType == currentSignType)
                .ToList();

            foreach (var sign in signs)
            {
                var location = new Point3D { X = sign.X, Y = sign.Y, Z = sign.Z };
                var existingEntity = vendors.FirstOrDefault(v => 
                    v.Sign == currentSignType && 
                    v.Location.X == location.X && 
                    v.Location.Y == location.Y && 
                    v.Location.Z == location.Z);

                if (existingEntity != null)
                {
                    // Remove vendors from all locations
                    foreach (var vendor in vendorsToRemove)
                    {
                        existingEntity.RemoveVendor(vendor);
                    }
                    // Add vendors to all locations
                    foreach (var vendor in vendorsToAdd)
                    {
                        existingEntity.AddVendor(vendor);
                    }
                    // Remove entity if no vendors left
                    if (existingEntity.VendorList.Count == 0)
                    {
                        vendors.Remove(existingEntity);
                    }
                }
                else if (vendorsToAdd.Count > 0)
                {
                    // Create new entity with the vendors to add
                    var newEntity = new VendorEntity(currentSignType, sign.Facing, location)
                    {
                        MapId = ViewService.CurrentMapId
                    };
                    newEntity.SetVendors(new List<string>(vendorsToAdd));
                    vendors.Add(newEntity);
                }
                locationsUpdated++;
            }
        }

        PathConstants.IsSpawnDataDirty = true;
        Utility.SaveVendorSpawnData();
        var typeName = FormatSignTypeName(currentSignType);
        Logger.Info($"Bulk updated {locationsUpdated} {typeName} locations: +{vendorsToAdd.Count} added, -{vendorsToRemove.Count} removed");

        CloseModal();
        await RenderVendorMarkers();
        StateHasChanged();
    }

    private string GetModalCategoryName()
    {
        var typeName = FormatSignTypeName(currentSignType);
        if (isBulkAddMode)
        {
            var locationCount = GetLocationCountForSignType(currentSignType);
            return $"{typeName} (All {locationCount} Locations)";
        }
        return $"{typeName} &#64; ({currentLocation.X}, {currentLocation.Y})";
    }

    private int GetLocationCountForSignType(SignTypes signType)
    {
        if (signType == SignTypes.MetalPost)
        {
            return HiveDataUtility.GetHivesForMap(ViewService.CurrentMapId).Count;
        }
        return SignDataUtility.GetSignsForMap(ViewService.CurrentMapId)
            .Count(s => s.SignType == signType);
    }

