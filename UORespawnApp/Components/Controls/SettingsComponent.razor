                            <span class="bi bi-terminal me-1"></span>
                            Debug Mode
                        </label>
                    </div>
                    <p class="text-muted small mb-0">
                        When enabled, a Debug Log panel appears on the right side showing live application logs.
                        <br />Use it to monitor app activity, add test markers, and copy logs for troubleshooting.
                    </p>
                </div>
            </div>

            <!-- Account Login Modal -->
            <AccountLoginModal 
                IsVisible="@showAccountModal" 
