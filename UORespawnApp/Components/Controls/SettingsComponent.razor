@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject BackgroundDataLoader BackgroundLoader
@inject ToastService ToastService
@inject DebugService DebugService
@inject SpawnPackService SpawnPackService
@inject AccountService AccountService
@inject MapImageCacheService MapImageCache
@using UORespawnApp.Scripts.Constants
@using UORespawnApp.Scripts.Utilities
@using UORespawnApp.Scripts.Services
@using UORespawnApp.Scripts.Entities
@using UORespawnApp.Components.Controls
@implements IDisposable

@code {
private string searchText = "";
private string? selectedSpawn = null;
private string selectedMapToReplace = "";
private string mapUploadMessage = "";
private bool mapUploadSuccess = false;
private bool hasMapBackup = false;
private string boxColorHex = "#8B0000";
private bool isAddingCustomMap = false; // Flag to distinguish between replace and add modes
private bool showCompleteResetModal = false;
private bool cleanServerOnReset = false;
private bool showBestiaryFavorites = false;
private bool showVendorFavorites = false;
private bool showAdvancedSettings = false;
    private bool showAccountModal = false;

    private void ToggleAdvancedSettings()
    {
        showAdvancedSettings = !showAdvancedSettings;
    }

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to bestiary and vendor list loaded events
        BackgroundLoader.BestiaryLoaded += OnBestiaryLoaded;
        BackgroundLoader.VendorListLoaded += OnVendorListLoaded;

        // Initialize box color hex from settings
        var color = Settings.BoxColor;
        boxColorHex = $"#{(int)(color.Red * 255):X2}{(int)(color.Green * 255):X2}{(int)(color.Blue * 255):X2}";

        // If bestiary is already loaded, trigger state update
        if (BackgroundLoader.IsBestiaryLoaded || BackgroundLoader.IsVendorListLoaded)
        {
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Scroll to top when page loads
            await JS.InvokeVoidAsync("scrollTo", new { top = 0, behavior = "instant" });
        }
    }

    private async Task ScrollToTop()
    {
        await JS.InvokeVoidAsync("scrollTo", new { top = 0, behavior = "smooth" });
    }

    private void OnBestiaryLoaded(object? sender, EventArgs e)
    {
        // Refresh UI when bestiary finishes loading
        InvokeAsync(StateHasChanged);
    }

    private void OnVendorListLoaded(object? sender, EventArgs e)
    {
        // Refresh UI when vendor list finishes loading
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        // Unsubscribe from events
        BackgroundLoader.BestiaryLoaded -= OnBestiaryLoaded;
        BackgroundLoader.VendorListLoaded -= OnVendorListLoaded;
    }

    private void ToggleDebugMode(ChangeEventArgs e)
    {
        var enabled = (bool)(e.Value ?? false);
        Settings.IsDebugMode = enabled;
        DebugService.SetEnabled(enabled);

        if (enabled)
        {
            Logger.Info("Debug mode enabled via Settings");
        }
        else
        {
            Logger.Info("Debug mode disabled via Settings");
        }

        StateHasChanged();
    }

    private List<string> GetFilteredSpawns()
    {
        if (BestiaryListUtility.BestiaryNameList == null)
        {
            return [];
        }

        // If showing favorites only, filter to favorites
        var sourceList = showBestiaryFavorites 
            ? BestiaryListUtility.BestiaryNameList.Where(s => Settings.BestiaryFavorites.Contains(s)).ToList()
            : BestiaryListUtility.BestiaryNameList;

        if (string.IsNullOrEmpty(searchText))
        {
            return sourceList;
        }

        return sourceList
            .Where(s => s.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private int GetSpawnCount()
    {
        return BestiaryListUtility.BestiaryNameList?.Count ?? 0;
    }

    private void SelectSpawn(string spawn)
    {
        selectedSpawn = spawn;
    }

    private void ClearSearch()
    {
        searchText = "";
    }

    private void ToggleBestiaryFavorite(string name)
    {
        Settings.ToggleBestiaryFavorite(name);
        StateHasChanged();
    }

    private void ToggleVendorFavorite(string name)
    {
        Settings.ToggleVendorFavorite(name);
        StateHasChanged();
    }

    // Vendor list state
    private string vendorSearchText = "";
    private string? selectedVendor = null;

    private List<string> GetFilteredVendors()
    {
        if (VendorListUtility.VendorNameList == null)
        {
            return [];
        }

        // If showing favorites only, filter to favorites
        var sourceList = showVendorFavorites 
            ? VendorListUtility.VendorNameList.Where(v => Settings.VendorFavorites.Contains(v)).ToList()
            : VendorListUtility.VendorNameList;

        if (string.IsNullOrEmpty(vendorSearchText))
        {
            return sourceList;
        }

        return sourceList
            .Where(v => v.Contains(vendorSearchText, StringComparison.OrdinalIgnoreCase))
