            <!-- Complete Reset Confirmation Modal -->
            @if (showCompleteResetModal)
            {
                <div class="modal fade show d-block" style="background: rgba(0,0,0,0.7);" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content bg-dark text-light">
                            <div class="modal-header border-danger">
                                <h5 class="modal-title text-danger">
                                    <span class="bi bi-exclamation-triangle me-2"></span>Factory Reset
                                </h5>
                                <button type="button" class="btn-close btn-close-white" @onclick="HideCompleteResetModal"></button>
                            </div>
                            <div class="modal-body">
                                <p><strong>This will restore the tool to fresh install state:</strong></p>
                                <ul>
                                    <li>All active spawn data (Box, Tile, Region, Vendor)</li>
                                    <li>All spawn settings reset to defaults</li>
                                    <li>Server link cleared</li>
                                </ul>
                                <p class="text-success"><span class="bi bi-check-circle me-2"></span><strong>Your Spawn Packs in PACKS folder will be preserved!</strong></p>

                                @if (ServerSetupUtility.IsServerConfigured(Settings.ServerFolder))
                                {
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" id="cleanServerCheck" @bind="cleanServerOnReset">
                                        <label class="form-check-label" for="cleanServerCheck">
