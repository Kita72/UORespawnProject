<div class="container-fluid p-3">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Page Header -->
            <div class="alert alert-dark mb-3 text-center shadow-sm">
                <h5 class="mb-0"><span class="bi bi-gear-fill me-2" style="color: goldenrod;"></span><span style="color: goldenrod;">Settings</span></h5>
            </div>

            <!-- ServUO Server Integration -->
            <ServerIntegrationCard OnShowAccountModal="ShowAccountModal" />

            <!-- Spawn Settings -->
            <div class="card map-card mb-3">
                <div class="card-header text-center">
                    <span class="text-primary" style="font-size: 1.25rem;"><span class="bi bi-sliders me-2"></span>Spawn Settings</span>
                    <InfoIcon Text="Server spawn behavior configuration" />
                </div>
                <div class="card-body">
                    <div class="row justify-content-center">
                        <div class="col-md-6 mb-3 text-center">
                            <label class="form-label">Min Range</label>
                            <input type="number" class="form-control text-center" @bind="Settings.MinRange" min="5" max="125" />
                        </div>
                        <div class="col-md-6 mb-3 text-center">
                            <label class="form-label">Max Range</label>
                            <input type="number" class="form-control text-center" @bind="Settings.MaxRange" min="5" max="250" />
                        </div>
                    </div>

                    <div class="row justify-content-center">
                        <div class="col-md-6 mb-3 text-center">
                            <label class="form-label">
                                Max Crowd
                                <InfoIcon Text="Maximum spawns within Min Range" />
                            </label>
                            <input type="number" class="form-control text-center" @bind="Settings.MaxCrowd" min="1" max="10" />
                        </div>
                        <div class="col-md-6 mb-3 text-center">
                            <label class="form-label">
                                Max Mobs
                                <InfoIcon Text="Maximum spawns within Max Range" />
                            </label>
                            <input type="number" class="form-control text-center" @bind="Settings.MaxMobs" min="5" max="75" />
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h6 class="mb-3 text-center">
                        <span class="text-primary" style="font-size: 1.25rem; font-weight: normal;"><span class="bi bi-dice-5 me-2"></span>Spawn Chances</span>
                        <InfoIcon Text="0.0 = 0% chance, 1.0 = 100% chance" />
                    </h6>

                    <div class="row justify-content-center">
                        <div class="col-md-4 mb-3 text-center">
                            <label class="form-label">Common</label>
                            <input type="number" class="form-control text-center" @bind="Settings.CommonChance" min="0" max="1" step="0.1" />
                        </div>
                        <div class="col-md-4 mb-3 text-center">
                            <label class="form-label">Uncommon</label>
                            <input type="number" class="form-control text-center" @bind="Settings.UnCommonChance" min="0" max="1" step="0.1" />
                        </div>
                        <div class="col-md-4 mb-3 text-center">
                            <label class="form-label">Rare</label>
                            <input type="number" class="form-control text-center" @bind="Settings.RareChance" min="0" max="1" step="0.1" />
                        </div>
                    </div>

                    <div class="row justify-content-center">
                        <div class="col-md-4 mb-3 text-center">
                            <label class="form-label">Water</label>
                            <input type="number" class="form-control text-center" @bind="Settings.WaterChance" min="0" max="1" step="0.1" />
                        </div>
                        <div class="col-md-4 mb-3 text-center">
                            <label class="form-label">Weather</label>
                            <input type="number" class="form-control text-center" @bind="Settings.WeatherChance" min="0" max="1" step="0.1" />
                        </div>
                        <div class="col-md-4 mb-3 text-center">
                            <label class="form-label">Timed</label>
                            <input type="number" class="form-control text-center" @bind="Settings.TimedChance" min="0" max="1" step="0.1" />
                        </div>
                    </div>

                    <hr class="my-4" />

                    <h6 class="mb-3 text-center"><span class="text-primary" style="font-size: 1.25rem; font-weight: normal;"><span class="bi bi-stars me-2"></span>Special Features</span></h6>

                    <div class="row justify-content-center">
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.IsScaleSpawn" id="scaleSpawn">
                                <label class="form-check-label" for="scaleSpawn">
                                    Scale Spawn
                                    <InfoIcon Text="Scales spawn around player" />
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableRiftSpawn" id="riftSpawn">
                                <label class="form-check-label" for="riftSpawn">
                                    Rift Spawn
                                    <InfoIcon Text="Trammel to Felucca portal spawns" />
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableDebugSpawn" id="debugSpawn">
                                <label class="form-check-label" for="debugSpawn">
                                    Debug Spawn
                                    <InfoIcon Text="Visual placeholders for testing" />
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <!-- Vendor Spawn Subsection -->
                    <h6 class="mb-3 text-center">
                        <span class="text-primary" style="font-size: 1.25rem; font-weight: normal;">
                            <span class="bi bi-shop me-2"></span>Vendor Spawn
                        </span>
                        <InfoIcon Text="NPC vendor spawning in towns" />
                    </h6>

                    <div class="row justify-content-center">
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableVendorSpawn" id="vendorSpawn" style="transform: scale(1.2);">
                                <label class="form-check-label" for="vendorSpawn" style="font-size: 1.05rem;">
                                    @(Settings.EnableVendorSpawn ? "Enabled" : "Disabled")
                                    <InfoIcon Text="Toggle vendor spawn system" />
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableVendorNight" id="vendorNight">
                                <label class="form-check-label" for="vendorNight">
                                    Night Sleep
                                    <InfoIcon Text="Vendors hide at night when enabled" />
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableVendorExtra" id="vendorExtra">
                                <label class="form-check-label" for="vendorExtra">
                                    Extra Patrons
                                    <InfoIcon Text="Add extra patrons to vendors" />
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <!-- Additional Spawn Toggles (Server 2.0.0.7+) -->
                    <h6 class="mb-3 text-center">
                        <span class="text-primary" style="font-size: 1.25rem; font-weight: normal;">
                            <span class="bi bi-toggles me-2"></span>Additional Toggles
                        </span>
                        <InfoIcon Text="Additional spawn behavior controls" />
                    </h6>

                    <div class="row justify-content-center">
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableTownSpawn" id="townSpawn">
                                <label class="form-check-label" for="townSpawn">
                                    Town Spawn
                                    <InfoIcon Text="Adds extra NPCs to the towns" />
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableGraveSpawn" id="graveSpawn">
                                <label class="form-check-label" for="graveSpawn">
                                    Grave Spawn
                                    <InfoIcon Text="Enable graves to add undead" />
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 text-center">
                            <div class="form-check form-switch d-inline-block text-start mb-3">
                                <input class="form-check-input" type="checkbox" @bind="Settings.EnableSpawnEffects" id="spawnEffects">
                                <label class="form-check-label" for="spawnEffects">
                                    Spawn Effects
                                    <InfoIcon Text="Show visual spawn effects" />
                                </label>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <!-- Advanced Settings Section (Collapsible) -->
                    <div class="d-flex align-items-center justify-content-center gap-2 mb-3" style="cursor: pointer;" @onclick="ToggleAdvancedSettings">
                        <span class="bi bi-gear-wide-connected text-info"></span>
                        <strong class="text-info">Advanced Server Settings</strong>
                        <span class="bi @(showAdvancedSettings ? "bi-chevron-up" : "bi-chevron-down") text-info small"></span>
                    </div>

                    @if (showAdvancedSettings)
                    {
                        <div class="card bg-dark text-light mb-3">
                            <div class="card-body">
                                <!-- Scale Modifier -->
                                <div class="row justify-content-center mb-3">
                                    <div class="col-md-6 text-center">
                                        <label class="form-label">
                                            Scale Modifier
                                            <InfoIcon Text="Multiplier for spawn limits when Scale Spawn is enabled (0.1-3.0)" />
                                        </label>
                                        <input type="number" class="form-control text-center" @bind="Settings.ScaleMod" min="0.1" max="3.0" step="0.1" />
                                    </div>
                                </div>

                                <hr class="my-3" />

                                <!-- System Intervals -->
                                <h6 class="mb-3 text-center text-info">
                                    <span class="bi bi-clock me-2"></span>System Intervals
                                </h6>
                                <div class="row justify-content-center">
                                    <div class="col-md-3 mb-3 text-center">
                                        <label class="form-label small">Search (ms)</label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.SearchInterval" min="50" max="2000" />
                                    </div>
                                    <div class="col-md-3 mb-3 text-center">
                                        <label class="form-label small">Process (ms)</label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.ProcessInterval" min="50" max="2000" />
                                    </div>
                                    <div class="col-md-3 mb-3 text-center">
                                        <label class="form-label small">Validate (sec)</label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.ValidateInterval" min="1" max="60" />
                                    </div>
                                    <div class="col-md-3 mb-3 text-center">
                                        <label class="form-label small">Timed (min)</label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.TimedInterval" min="1" max="60" />
                                    </div>
                                </div>

                                <hr class="my-3" />

                                <!-- System Limits -->
                                <h6 class="mb-3 text-center text-info">
                                    <span class="bi bi-speedometer2 me-2"></span>System Limits
                                </h6>
                                <div class="row justify-content-center">
                                    <div class="col-md-4 mb-3 text-center">
                                        <label class="form-label small">
                                            Max Recycle/Type
                                            <InfoIcon Text="Max mobs cached per creature type" />
                                        </label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.MaxRecycleType" min="1" max="100" />
                                    </div>
                                    <div class="col-md-4 mb-3 text-center">
                                        <label class="form-label small">
                                            Max Spawn Checks
                                            <InfoIcon Text="Max attempts to find valid spawn point" />
                                        </label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.MaxSpawnChecks" min="1" max="10" />
                                    </div>
                                    <div class="col-md-4 mb-3 text-center">
                                        <label class="form-label small">
                                            Max Queue Size
                                            <InfoIcon Text="Max spawn locations queued per player" />
                                        </label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.MaxQueueSize" min="1" max="10" />
                                    </div>
                                    <div class="col-md-4 mb-3 text-center">
                                        <label class="form-label small">
                                            Max Stat Size
                                            <InfoIcon Text="Max statistics entries tracked" />
                                        </label>
                                        <input type="number" class="form-control form-control-sm text-center" @bind="Settings.MaxStatSize" min="100" max="10000" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Tool Settings -->
            <div class="card map-card mb-3">
                <div class="card-header text-center">
                    <span class="text-primary" style="font-size: 1.25rem;"><span class="bi bi-palette me-2"></span>Spawn Box Appearance</span>
                    <InfoIcon Text="Customize box colors and line thickness" />
                </div>
                <div class="card-body">
                    <div class="row justify-content-center">
                        <div class="col-12 text-center mb-3">
                            <label class="form-label">Base Box Color (Priority 0)</label>
                            <div class="d-flex gap-2 align-items-center justify-content-center">
                                <input type="color" class="form-control form-control-color" @bind="boxColorHex" style="width: 60px; height: 38px;" />
                                <input type="text" class="form-control text-center" @bind="boxColorHex" placeholder="#FF0000" style="max-width: 120px;" />
                            </div>
                        </div>
                        <div class="col-12 text-center mb-3">
                            <label class="form-label">Line Thickness</label>
                            <select class="form-select text-center" style="max-width: 150px; margin: 0 auto;" @bind="Settings.BoxLineSize">
                                <option value="1">1 px</option>
                                <option value="2">2 px</option>
                                <option value="3">3 px</option>
                                <option value="4">4 px</option>
                                <option value="5">5 px</option>
                            </select>
                        </div>
                        <div class="col-12 text-center">
                            <span class="text-muted small">
                                Priority Colors
                                <InfoIcon Text="Boxes use distinct colors by priority level" />
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map Management -->
            <div class="card map-card mb-3">
                <div class="card-header text-center">
                    <span class="text-primary" style="font-size: 1.25rem;"><span class="bi bi-map me-2"></span>Map Management</span>
                    <InfoIcon Text="Add, replace, or remove map images" />
                </div>
                <div class="card-body">
                    <!-- Map Status Summary - Split Pill Badge -->
                    <div class="text-center mb-4">
                        <div class="d-inline-flex align-items-center" style="font-size: 1.1rem; border-radius: 50px; overflow: hidden; box-shadow: 0 3px 6px rgba(0,0,0,0.15); min-width: 300px;">
                            <span class="badge bg-success" style="padding: 12px 24px; border-radius: 0; margin: 0; flex: 1;">
                                <span class="bi bi-map me-2"></span>
                                @{
                                    var availableMaps = GetAvailableMaps();
                                    var originalCount = availableMaps.Count(id => id < FirstCustomMapId);
                                    var customCount = availableMaps.Count(id => id >= FirstCustomMapId);
                                }
                                @originalCount Original
                            </span>
                            <span class="badge bg-danger" style="padding: 12px 24px; border-radius: 0; margin: 0; flex: 1;">
                                <span class="bi bi-plus-circle me-2"></span>
                                @customCount Custom
                            </span>
                        </div>
                    </div>

                    <!-- Replace Existing Map -->
                    <div class="mb-4 text-center">
                        <div class="d-flex justify-content-center mb-2">
                            <select class="form-select" style="width: 300px;" @bind="selectedMapToReplace" @bind:after="OnMapSelectionChanged">
                                <option value="">Select map to replace...</option>
                                @foreach (var mapId in GetAvailableMaps())
                                {
                                    var mapName = $"Map{mapId}";
                                    var friendlyName = MapUtility.GetMapName(mapId);
                                    var dims = GetMapDimensions(mapName);

                                    <option value="@mapName">
                                        @mapName - @friendlyName (@dims.width x @dims.height)
                                    </option>
                                }
                            </select>
                            <span class="bi bi-info-circle ms-2 align-self-center" style="color: #6c757d; cursor: help;" title="Select a map to replace with your custom image"></span>
                        </div>

                        @if (hasMapBackup && !string.IsNullOrEmpty(selectedMapToReplace))
                        {
                            <button class="btn btn-outline-warning btn-sm" @onclick="RestoreMapBackup">
                                <span class="bi bi-arrow-counterclockwise"></span> Restore Original
                            </button>
                        }
                    </div>

                    <hr class="my-4" />

                    <!-- Add Custom Map -->
                    <div class="mt-4 text-center">
                        @{
                            var nextCustomMap = GetNextCustomMapNumber();
                        }
                        @if (nextCustomMap == -1)
                        {
                            <div class="alert alert-warning mb-0" style="width: 300px; margin: 0 auto;">
                                <span class="bi bi-exclamation-triangle"></span> Requires all original maps (0-5) first
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-primary" style="width: 300px;" @onclick="BrowseMapImageAdd">
                                <span class="bi bi-plus-lg"></span> Add Map@(nextCustomMap)
                            </button>
                        }
                    </div>

                    <!-- Delete Custom Map -->
                    @{
                        var highestCustom = GetHighestCustomMapNumber();
                    }
                    @if (highestCustom >= FirstCustomMapId)
                    {
                        <div class="mb-3 text-center">
                            <label class="form-label fw-bold">Delete Custom Map</label>
                            <button class="btn btn-danger" style="min-width: 200px;" @onclick="() => DeleteCustomMap(highestCustom)">
                                <span class="bi bi-trash"></span> Delete Map@(highestCustom)
                            </button>
                        </div>
                    }

                    <!-- Status Messages -->
                    @if (!string.IsNullOrEmpty(mapUploadMessage))
                    {
                        <div class="alert @(mapUploadSuccess ? "alert-success" : "alert-danger") mt-3 mb-0 text-center">
                            @mapUploadMessage
                        </div>
                    }
                </div>
            </div>

            <!-- Bestiary -->
            <div class="card map-card mb-3">
                <div class="card-header text-center">
                    <span class="text-primary" style="font-size: 1.25rem;"><span class="bi bi-book me-2"></span>Bestiary (@GetSpawnCount() Creatures)</span>
                    <InfoIcon Text="Star creatures to add them to favorites" />
                </div>
                <div class="card-body">
                    <!-- Tab Toggle -->
                    <div class="btn-group w-100 mb-3" role="group">
                        <button class="btn @(showBestiaryFavorites ? "btn-outline-primary" : "btn-primary")" @onclick="() => showBestiaryFavorites = false">
                            <span class="bi bi-list me-1"></span>All (@GetSpawnCount())
                        </button>
                        <button class="btn @(showBestiaryFavorites ? "btn-warning" : "btn-outline-warning")" @onclick="() => showBestiaryFavorites = true">
                            <span class="bi bi-star-fill me-1"></span>Favorites (@Settings.BestiaryFavorites.Count)
                        </button>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text"><span class="bi bi-search"></span></span>
                        <input type="text" class="form-control" placeholder="Search creatures..." @bind="searchText" @bind:event="oninput" />
                        <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                            <span class="bi bi-x-lg"></span>
                        </button>
                    </div>

                    <div class="bestiary-list">
                        @if (!BackgroundLoader.IsBestiaryLoaded)
                        {
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary mb-3" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mb-0">Loading bestiary...</p>
                                <small class="text-muted">@GetSpawnCount() creatures</small>
                            </div>
                        }
                        else if (GetFilteredSpawns().Any())
                        {
                            @foreach (var spawn in GetFilteredSpawns())
                            {
                                var isFavorite = Settings.BestiaryFavorites.Contains(spawn);
                                <div class="bestiary-item @(selectedSpawn == spawn ? "selected" : "") @(isFavorite ? "is-favorite" : "")" @onclick="() => SelectSpawn(spawn)">
                                    <button class="btn btn-sm favorite-btn @(isFavorite ? "active" : "")" 
                                            @onclick:stopPropagation="true"
                                            @onclick="() => ToggleBestiaryFavorite(spawn)"
                                            title="@(isFavorite ? "Remove from favorites" : "Add to favorites")">
                                        <span class="bi @(isFavorite ? "bi-star-fill text-warning" : "bi-star")"></span>
                                    </button>
                                    <span class="spawn-name">@spawn</span>
                                </div>
                            }
                        }
                        else if (showBestiaryFavorites)
                        {
                            <div class="alert alert-info mb-0">
                                <span class="bi bi-star me-2"></span>No favorites yet. Click the star on any creature to add it to your favorites.
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(searchText))
                        {
                            <div class="alert alert-info mb-0">
                                No creatures found matching "@searchText"
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">
                                No creatures in bestiary. Link to a server to load the creature list.
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Vendor List -->
            <div class="card map-card mb-3">
                <div class="card-header text-center">
                    <span class="text-primary" style="font-size: 1.25rem;"><span class="bi bi-shop me-2"></span>Vendor List (@GetVendorCount() Vendors)</span>
                    <InfoIcon Text="Star vendors to add them to favorites" />
                </div>
                <div class="card-body">
                    <!-- Tab Toggle -->
                    <div class="btn-group w-100 mb-3" role="group">
                        <button class="btn @(showVendorFavorites ? "btn-outline-primary" : "btn-primary")" @onclick="() => showVendorFavorites = false">
                            <span class="bi bi-list me-1"></span>All (@GetVendorCount())
                        </button>
                        <button class="btn @(showVendorFavorites ? "btn-warning" : "btn-outline-warning")" @onclick="() => showVendorFavorites = true">
                            <span class="bi bi-star-fill me-1"></span>Favorites (@Settings.VendorFavorites.Count)
                        </button>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text"><span class="bi bi-search"></span></span>
                        <input type="text" class="form-control" placeholder="Search vendors..." @bind="vendorSearchText" @bind:event="oninput" />
                        <button class="btn btn-outline-secondary" @onclick="ClearVendorSearch">
                            <span class="bi bi-x-lg"></span>
                        </button>
                    </div>

                    <div class="bestiary-list">
                        @if (!BackgroundLoader.IsVendorListLoaded)
                        {
                            <div class="text-center py-4">
                                <div class="spinner-border text-primary mb-3" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <p class="text-muted mb-0">Loading vendor list...</p>
                                <small class="text-muted">@GetVendorCount() vendors</small>
                            </div>
                        }
                        else if (GetFilteredVendors().Any())
                        {
                            @foreach (var vendor in GetFilteredVendors())
                            {
                                var isFavorite = Settings.VendorFavorites.Contains(vendor);
                                <div class="bestiary-item @(selectedVendor == vendor ? "selected" : "") @(isFavorite ? "is-favorite" : "")" @onclick="() => SelectVendor(vendor)">
                                    <button class="btn btn-sm favorite-btn @(isFavorite ? "active" : "")" 
                                            @onclick:stopPropagation="true"
                                            @onclick="() => ToggleVendorFavorite(vendor)"
                                            title="@(isFavorite ? "Remove from favorites" : "Add to favorites")">
                                        <span class="bi @(isFavorite ? "bi-star-fill text-warning" : "bi-star")"></span>
                                    </button>
                                    <span class="spawn-name">@vendor</span>
                                </div>
                            }
