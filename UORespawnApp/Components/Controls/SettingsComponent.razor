                                            <span class="bi bi-exclamation-octagon me-2"></span>
                                            <strong>Server Cleanup Warning:</strong>
                                            <p class="mb-0 mt-2 small">
                                                This will delete the <code>UORespawnServer</code> scripts folder and <code>UORespawn</code> data folder from your server.
                                            </p>
                                            <p class="mb-0 mt-2 small">
                                                <strong class="text-warning">IMPORTANT:</strong> Before proceeding, ensure no UORespawn mobiles are spawned in the world! 
                                                Use <code>[ClearRespawn</code> in-game first. Removing scripts while mobiles exist will cause server load errors.
                                            </p>
                                        </div>
                                    }
                                }

                                <p class="text-danger mt-3"><strong>This action cannot be undone!</strong></p>
                            </div>
                            <div class="modal-footer border-secondary">
                                <button type="button" class="btn btn-secondary" @onclick="HideCompleteResetModal">Cancel</button>
                                <button type="button" class="btn btn-danger" @onclick="ExecuteCompleteReset">
                                    <span class="bi bi-trash me-2"></span>Factory Reset
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

