@using Microsoft.JSInterop
@using UORespawnApp.Scripts.Constants
@using UORespawnApp.Scripts.Utilities
@using UORespawnApp.Scripts.Entities
@using UORespawnApp.Scripts.Services
@inject IJSRuntime JS
@inject ViewService ViewService
@inject ToastService ToastService

<div>
    <!-- Simplified Header with Map Selector -->
    <div class="alert alert-dark mb-3 d-flex justify-content-between align-items-center shadow-sm">
        <div class="d-flex align-items-center gap-2">
            <span class="bi bi-grid-3x3-gap" style="color: goldenrod;"></span>
            <select class="form-select form-select-sm map-header-select" 
                    @bind:get="ViewService.CurrentMapId" 
                    @bind:set="OnMapChanged"
                    style="width: auto; min-width: 120px;">
                @foreach (var mapId in GetAvailableMaps())
                {
                    <option value="@mapId">@MapUtility.GetMapName(mapId)</option>
                }
            </select>
        </div>
        <h5 class="mb-0"><span style="color: goldenrod;">Tile Spawn</span></h5>
        <span class="bi bi-info-circle" style="color: #6c757d; cursor: help;" title="Configure spawns based on ground tile types. Animals and Creatures spawn on matching terrain across all maps."></span>
    </div>

    <div class="row g-3">
        <!-- LEFT: Tile Image Viewer -->
        <div class="col-lg-3">
            <div class="card map-card tile-column-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong style="color: goldenrod;">Tile Preview</strong>
                    @if (selectedTile != null)
                    {
                        <span class="tile-category-badge @GetCategoryClass(GetCurrentTileDescription().Category)">@GetCurrentTileDescription().Category</span>
                    }
                </div>
                <div class="card-body tile-image-body">
                    @if (selectedTile != null)
                    {
                        <div class="tile-image-wrapper">
                            <img src="@GetTileImageUrl()" alt="@selectedTile" class="tile-image" />
                        </div>
                        <div class="tile-image-label">
                            <span class="tile-display-name">@GetTileDisplayName(selectedTile)</span>
                            <span class="tile-subtitle">@GetCurrentTileDescription().Title</span>
                        </div>
                        <div class="tile-description-section">
                            <p class="tile-description-text">@GetCurrentTileDescription().Description</p>
                            @if (!TileImageUtility.HasTileImage(selectedTile))
                            {
                                <div class="tile-no-image-note">
                                    <span class="bi bi-info-circle me-1"></span>
                                    <span>This tile group has multiple visual variants. The preview shows a placeholder image.</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="tile-image-placeholder">
                            <span class="bi bi-grid-3x3-gap" style="font-size: 3rem; opacity: 0.3;"></span>
                            <p class="text-muted mt-2 mb-0">Select a tile type</p>
                            <small class="text-muted">from the list on the right</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- MIDDLE: Spawn Configuration -->
        <div class="col-lg-6">
            @if (selectedTile != null)
            {
                <div class="card map-card tile-column-card">
                        <div class="card-header text-center d-flex justify-content-between align-items-center">
                            <div style="width: 40px;"></div>
                            <strong style="color: #6ea8fe;">@GetTileDisplayName(selectedTile)</strong>
                            @if (currentEntity.GetTotalSpawnCount() > 0)
                        {
                            <button class="btn btn-warning" style="padding: 2px 6px; font-size: 0.7rem;" @onclick="() => ClearTileSpawns()" title="Clear All Spawns for this Tile">
                                <span class="bi bi-arrow-clockwise"></span>
                            </button>
                        }
                        else
                        {
                            <div style="width: 40px;"></div>
                        }
                    </div>
                    <div class="card-body tile-config-body">
                        <!-- 6 Spawn Category Buttons -->
                        <FrequencyButtonsComponent
                            WaterCount="@currentEntity.WaterSpawns.Count"
                            WeatherCount="@currentEntity.WeatherSpawns.Count"
                            TimedCount="@currentEntity.TimedSpawns.Count"
                            CommonCount="@currentEntity.CommonSpawns.Count"
                            UncommonCount="@currentEntity.UncommonSpawns.Count"
                            RareCount="@currentEntity.RareSpawns.Count"
                            OnButtonClick="OpenModal" />

                        <!-- Trigger icons + dropdowns grouped together at bottom -->
                        <div class="trigger-bottom-group">
                            <div class="trigger-display-section">
                                <div class="trigger-display-cell trigger-display-cell--left">
                                    <i class="bi @GetWeatherIcon(currentEntity.WeatherSpawn) trigger-display-icon"
                                       style="@GetWeatherIconColor(currentEntity.WeatherSpawn)"></i>
                                    <span class="badge @GetWeatherBadgeClass(currentEntity.WeatherSpawn) mt-2">
                                        @(currentEntity.WeatherSpawn == WeatherTypes.None ? "No Weather" : currentEntity.WeatherSpawn.ToString())
                                    </span>
                                </div>
                                <div class="trigger-display-cell">
                                    <i class="bi @GetTimeIcon(currentEntity.TimedSpawn) trigger-display-icon"
                                       style="@GetTimeIconColor(currentEntity.TimedSpawn)"></i>
                                    <span class="badge @GetTimeBadgeClass(currentEntity.TimedSpawn) mt-2">
                                        @(currentEntity.TimedSpawn == TimeNames.None ? "No Time" : currentEntity.TimedSpawn.ToString().Replace("_", " "))
                                    </span>
                                </div>
                            </div>

                            <!-- Trigger Dropdowns -->
                            <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label mb-1 text-center d-block">
                                    Weather Trigger
                                    <span class="bi bi-info-circle ms-1" style="color: #6c757d; cursor: help;" title="Activates when weather has spawn"></span>
                                </label>
                                <select class="form-select form-select-sm" 
                                        @bind="currentEntity.WeatherSpawn" 
                                        @bind:after="SaveCurrentTile"
                                        disabled="@(currentEntity.WeatherSpawns.Count == 0)">
                                    @if (currentEntity.WeatherSpawns.Count == 0)
                                    {
                                        <option value="@WeatherTypes.None">None</option>
                                    }
                                    else
                                    {
                                        @foreach (var weather in Enum.GetValues<WeatherTypes>().Where(w => w != WeatherTypes.None))
                                        {
                                            <option value="@weather">@weather.ToString()</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label mb-1 text-center d-block">
                                    Timed Trigger
                                    <span class="bi bi-info-circle ms-1" style="color: #6c757d; cursor: help;" title="Activates when timed has spawn"></span>
                                </label>
                                <select class="form-select form-select-sm" 
                                        @bind="currentEntity.TimedSpawn" 
                                        @bind:after="SaveCurrentTile"
                                        disabled="@(currentEntity.TimedSpawns.Count == 0)">
                                    @if (currentEntity.TimedSpawns.Count == 0)
                                    {
                                        <option value="@TimeNames.None">None</option>
                                    }
                                    else
                                    {
                                        @foreach (var time in Enum.GetValues<TimeNames>().Where(t => t != TimeNames.None))
                                        {
                                            <option value="@time">@time.ToString().Replace("_", " ")</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        </div><!-- /trigger-bottom-group -->
                    </div>
                </div>
            }
            else
            {
                <div class="card map-card tile-column-card">
                    <div class="card-body text-center py-5">
                        <span class="bi bi-grid-3x3-gap" style="font-size: 3rem; opacity: 0.3;"></span>
                        <p class="text-muted mt-3">Select a tile type from the right to configure spawns</p>
                    </div>
                </div>
            }
        </div>

        <!-- RIGHT: Tile Selection List -->
        <div class="col-lg-3">
            <div class="card map-card tile-column-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong style="color: goldenrod;">Tile Types</strong>
                    <span class="badge bg-light text-dark" title="Total spawns across all tile types">@GetTotalAllTileSpawnCount() Spawns</span>
                </div>
                <div class="card-body p-2 tile-list-body">
                    <div class="tile-list">
                        @foreach (var tileName in TileListUtility.GetTileList())
                        {
                            var displayName = GetTileDisplayName(tileName);
                            var totalSpawns = GetTileEntityTotalSpawnCount(tileName);
                            <div class="tile-item @(selectedTile == tileName ? "selected" : "")" 
                                 @onclick="() => SelectTile(tileName)">
                                <span class="tile-name">@displayName</span>
                                @if (totalSpawns > 0)
                                {
                                    <span class="badge bg-primary">@totalSpawns</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Ecology Banner Footer -->
    <div class="ecology-banner-card mt-3">
        <div class="card shadow-sm">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div class="d-flex align-items-center">
                    <span class="bi bi-book ecology-banner-icon me-3"></span>
                    <div>
                        <h6 class="mb-1 ecology-banner-title">Ecological Dynamics & Spawn Architecture</h6>
                        <p class="mb-0 text-muted small">Learn about the six-frequency system, terrain classifications, and the philosophy behind the UORespawn living shard simulation.</p>
                    </div>
                </div>
                <button class="btn btn-outline-warning ecology-banner-btn" @onclick="OpenEcologyModal">
                    <span class="bi bi-journal-text me-1"></span>
                    Read Ecology Guide
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Spawn Category Modal -->
<SpawnCategoryModal IsVisible="@showModal"
                    CategoryName="@currentFrequency.ToString()"
                    SpawnTypeName="Spawns"
                    SourceListName="Bestiary"
                    CurrentSpawns="@currentCategorySpawns"
                    SourceList="@(BestiaryListUtility.BestiaryNameList ?? new List<string>())"
                    OnClose="@CloseModal"
                    OnSave="@SaveModal" />

<!-- Ecology Modal -->
<EcologyModal IsVisible="@showEcologyModal" OnClose="CloseEcologyModal" />

@code {
    private string? selectedTile = null;
    private TileSpawnEntity currentEntity = new();
    private bool showModal = false;
    private bool showEcologyModal = false;
    private Frequency currentFrequency = Frequency.Common;
    private List<string> currentCategorySpawns = new();
    private string? currentTileImageUrl = null;

    protected override void OnInitialized()
    {
        // Data is already loaded by BackgroundDataLoader
        var totalTiles = Utility.TileSpawns.Values.Sum(list => list.Count);
        Logger.Info($"TileSpawnComponent initialized - {totalTiles} tile configurations across all maps");

        // Restore last selected tile from session, or auto-select first tile on initial visit
        if (Utility.SESSION != null)
        {
            if (Utility.SESSION.HasVisitedTileSpawnPage && !string.IsNullOrEmpty(Utility.SESSION.LastSelectedTile))
            {
                // Restore previous selection (only if tile still exists in list)
                var lastTile = Utility.SESSION.LastSelectedTile;
                if (TileListUtility.IsValidTileName(lastTile))
                {
                    selectedTile = lastTile;
                    SelectTile(lastTile);
                    Logger.Info($"Restored tile selection from session: {selectedTile}");
                }
                else
                {
                    // Tile no longer exists in list, select first available
                    SelectFirstTile();
                }
            }
            else
            {
                // First visit - auto-select first tile
                SelectFirstTile();
            }
        }
    }

    private void SelectFirstTile()
    {
        var tileList = TileListUtility.GetTileList();
        if (tileList.Count > 0)
        {
            var firstTile = tileList[0];
            selectedTile = firstTile;
            SelectTile(firstTile);
            if (Utility.SESSION != null)
            {
                Utility.SESSION.LastSelectedTile = firstTile;
            }
            Logger.Info($"Auto-selected first tile: {firstTile}");
        }
    }

    private void SelectTile(string tileName)
    {
        selectedTile = tileName;

        // Update tile image URL
        currentTileImageUrl = TileImageUtility.GetTileImageDataUrl(tileName);

        // Save selection to session for persistence during runtime
        if (Utility.SESSION != null)
        {
            Utility.SESSION.LastSelectedTile = tileName;
        }

        // Find or create TileSpawnEntity for this tile on current map
        if (Utility.SESSION != null)
        {
            var currentMapId = Utility.SESSION.CurrentMap;

            var tileList = Utility.GetOrCreateTileList(currentMapId);

            var existing = tileList.FirstOrDefault(t => t.Name.Equals(tileName, StringComparison.OrdinalIgnoreCase));

            if (existing != null)
            {
                currentEntity = existing;
            }
            else
            {
                // Create new entity for this tile
                var nextId = tileList.Count > 0 ? tileList.Max(t => t.Id) + 1 : 1;
                currentEntity = new TileSpawnEntity
                {
                    Id = nextId,
                    Name = tileName.ToLowerInvariant(),
                    MapId = currentMapId
                };
                tileList.Add(currentEntity);
                Logger.Info($"Created new TileSpawnEntity for {tileName} on map {currentMapId}");
            }
        }

        StateHasChanged();
    }

    private string GetTileImageUrl()
    {
        if (string.IsNullOrEmpty(currentTileImageUrl) && selectedTile != null)
        {
            currentTileImageUrl = TileImageUtility.GetTileImageDataUrl(selectedTile);
        }
        return currentTileImageUrl ?? string.Empty;
    }

    private string GetTileDisplayName(string? tileName)
    {
        if (string.IsNullOrEmpty(tileName))
            return "Unknown";
        return tileName.Replace('_', ' ').ToTitleCase();
    }

    private string GetCategoryClass(string category)
    {
        return category.ToLowerInvariant() switch
        {
            "natural" => "category-natural",
            "constructed" => "category-constructed",
            "exotic" => "category-exotic",
            "custom" => "category-custom",
            _ => "category-custom"
        };
    }

    #region Trigger Dashboard Helpers

    private string GetWeatherIcon(WeatherTypes weather) => weather switch
    {
        WeatherTypes.Rain => "bi-cloud-rain-fill",
        WeatherTypes.Snow => "bi-snow",
        WeatherTypes.Storm => "bi-cloud-lightning-fill",
        WeatherTypes.Blizzard => "bi-cloud-snow",
        _ => "bi-cloud"
    };

    private string GetWeatherIconColor(WeatherTypes weather) => weather switch
    {
        WeatherTypes.Rain => "color: #6ea8fe;",
        WeatherTypes.Snow => "color: #e0e0e0;",
        WeatherTypes.Storm => "color: #ffc107;",
        WeatherTypes.Blizzard => "color: #b8d4e8;",
        _ => "color: #6c757d; opacity: 0.5;"
    };

    private string GetWeatherBadgeClass(WeatherTypes weather) => weather switch
    {
        WeatherTypes.None => "bg-secondary",
        WeatherTypes.Rain => "bg-primary",
        WeatherTypes.Snow => "bg-light text-dark",
        WeatherTypes.Storm => "bg-warning text-dark",
        WeatherTypes.Blizzard => "bg-info",
        _ => "bg-secondary"
    };

    private string GetTimeIcon(TimeNames time) => time switch
    {
        TimeNames.Witching_Hour => "bi-moon-stars-fill",
        TimeNames.Middle_of_Night => "bi-moon-fill",
        TimeNames.Late_at_Night => "bi-moon-fill",
        TimeNames.Early_Morning => "bi-sunrise-fill",
        TimeNames.Late_Morning => "bi-sun-fill",
        TimeNames.Noon => "bi-brightness-high-fill",
        TimeNames.Afternoon => "bi-sun-fill",
        TimeNames.Early_Evening => "bi-sunset-fill",
        _ => "bi-clock"
    };

    private string GetTimeIconColor(TimeNames time) => time switch
    {
        TimeNames.Witching_Hour => "color: #9b59b6;",
        TimeNames.Middle_of_Night => "color: #3498db;",
        TimeNames.Late_at_Night => "color: #2c3e50;",
        TimeNames.Early_Morning => "color: #f39c12;",
        TimeNames.Late_Morning => "color: #f1c40f;",
        TimeNames.Noon => "color: #f1c40f;",
        TimeNames.Afternoon => "color: #e67e22;",
        TimeNames.Early_Evening => "color: #e74c3c;",
        _ => "color: #6c757d; opacity: 0.5;"
    };

    private string GetTimeBadgeClass(TimeNames time) => time switch
    {
        TimeNames.None => "bg-secondary",
        TimeNames.Witching_Hour => "bg-purple",
        TimeNames.Middle_of_Night or TimeNames.Late_at_Night => "bg-dark",
        TimeNames.Early_Morning or TimeNames.Early_Evening => "bg-warning text-dark",
        TimeNames.Late_Morning or TimeNames.Noon or TimeNames.Afternoon => "bg-warning text-dark",
        _ => "bg-secondary"
    };

    #endregion

    private TileDescription GetCurrentTileDescription()
    {
        return TileImageUtility.GetTileDescription(selectedTile ?? string.Empty);
    }

    private int GetTileEntityTotalSpawnCount(string tileName)
    {
        if (Utility.SESSION == null) return 0;

        var currentMapId = Utility.SESSION.CurrentMap;

        if (!Utility.TileSpawns.TryGetValue(currentMapId, out var tileList))
            return 0;

        var entity = tileList.FirstOrDefault(t => t.Name.Equals(tileName, StringComparison.OrdinalIgnoreCase));
        return entity?.GetTotalSpawnCount() ?? 0;
    }

    private void OpenModal(Frequency freq)
    {
        if (selectedTile == null) return;

        currentFrequency = freq;

        // Load current spawns for this category from currentEntity
        currentCategorySpawns = freq switch
        {
            Frequency.Water => new List<string>(currentEntity.WaterSpawns),
            Frequency.Weather => new List<string>(currentEntity.WeatherSpawns),
            Frequency.Timed => new List<string>(currentEntity.TimedSpawns),
            Frequency.Common => new List<string>(currentEntity.CommonSpawns),
            Frequency.UnCommon => new List<string>(currentEntity.UncommonSpawns),
            Frequency.Rare => new List<string>(currentEntity.RareSpawns),
            _ => new List<string>()
        };

        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        currentCategorySpawns.Clear();
        StateHasChanged();
    }

    private void SaveModal()
    {
        if (selectedTile == null) return;

        // Get the target list from currentEntity
        var targetList = currentFrequency switch
        {
            Frequency.Water => currentEntity.WaterSpawns,
            Frequency.Weather => currentEntity.WeatherSpawns,
            Frequency.Timed => currentEntity.TimedSpawns,
            Frequency.Common => currentEntity.CommonSpawns,
            Frequency.UnCommon => currentEntity.UncommonSpawns,
            Frequency.Rare => currentEntity.RareSpawns,
            _ => null
        };

        if (targetList != null)
        {
            targetList.Clear();

            // Only add non-empty names
            foreach (var name in currentCategorySpawns)
            {
                if (!string.IsNullOrWhiteSpace(name))
                {
                    targetList.Add(name);
                }
            }

            Logger.Info($"Saved {targetList.Count} {currentFrequency} spawns for {selectedTile}");

            // Auto-set trigger logic (matching BoxSpawnComponent behavior)
            if (currentFrequency == Frequency.Weather)
            {
                if (targetList.Count > 0 && currentEntity.WeatherSpawn == WeatherTypes.None)
                {
                    currentEntity.WeatherSpawn = WeatherTypes.Rain;
                    Logger.Info($"Auto-set Weather Trigger to Rain for {selectedTile}");
                }
                else if (targetList.Count == 0 && currentEntity.WeatherSpawn != WeatherTypes.None)
                {
                    currentEntity.WeatherSpawn = WeatherTypes.None;
                    Logger.Info($"Auto-reset Weather Trigger to None for {selectedTile}");
                }
            }
            else if (currentFrequency == Frequency.Timed)
            {
                if (targetList.Count > 0 && currentEntity.TimedSpawn == TimeNames.None)
                {
                    currentEntity.TimedSpawn = TimeNames.Witching_Hour;
                    Logger.Info($"Auto-set Time Trigger to Witching_Hour for {selectedTile}");
                }
                else if (targetList.Count == 0 && currentEntity.TimedSpawn != TimeNames.None)
                {
                    currentEntity.TimedSpawn = TimeNames.None;
                    Logger.Info($"Auto-reset Time Trigger to None for {selectedTile}");
                }
            }
        }

        // Mark data as dirty - spawn entries changed
        PathConstants.IsSpawnDataDirty = true;

        // Save to binary file
        SaveCurrentTile();

        StateHasChanged();
    }

    private void SaveCurrentTile()
    {
        try
        {
            Utility.SaveTileSpawnData();
            Logger.Info("Auto-saved tile spawn data");
        }
        catch (Exception ex)
        {
            Logger.Error("Error saving tile spawn data", ex);
            ToastService.ShowError($"Failed to save tile spawn data: {ex.Message}");
        }
    }

    private void ClearTileSpawns()
    {
        if (currentEntity == null) return;

        // Clear all spawn lists
        currentEntity.WaterSpawns.Clear();
        currentEntity.WeatherSpawns.Clear();
        currentEntity.TimedSpawns.Clear();
        currentEntity.CommonSpawns.Clear();
        currentEntity.UncommonSpawns.Clear();
        currentEntity.RareSpawns.Clear();

        // Reset triggers to None
        currentEntity.WeatherSpawn = WeatherTypes.None;
        currentEntity.TimedSpawn = TimeNames.None;

        // Mark data as dirty - spawns were cleared
        PathConstants.IsSpawnDataDirty = true;

        // Save changes
        SaveCurrentTile();

        // Show success message
        if (selectedTile != null)
        {
            ToastService.ShowSuccess($"Cleared all spawns for {GetTileDisplayName(selectedTile)}");

            Logger.Info($"Cleared all spawns for tile: {selectedTile}");
        }

        StateHasChanged();
    }

    private int GetTotalAllTileSpawnCount()
    {
        if (Utility.SESSION == null) return 0;

        if (!Utility.TileSpawns.TryGetValue(Utility.SESSION.CurrentMap, out var tileList))
        {
            return 0;
        }

        return tileList.Sum(t => t.GetTotalSpawnCount());
    }

    private void OpenEcologyModal()
    {
        showEcologyModal = true;
        StateHasChanged();
    }

    private void CloseEcologyModal()
    {
        showEcologyModal = false;
        StateHasChanged();
    }

    private List<int> GetAvailableMaps()
    {
        return MapUtility.GetAvailableMaps();
    }

    private void OnMapChanged(int newMapId)
    {
        ViewService.CurrentMapId = newMapId;

        // Update SESSION's CurrentMap - this is what the tile data uses
        if (Utility.SESSION != null)
        {
            Utility.SESSION.CurrentMap = newMapId;
        }

        // Re-select current tile for the new map (reloads entity data for new map)
        if (!string.IsNullOrEmpty(selectedTile))
        {
            SelectTile(selectedTile);
        }

        StateHasChanged();
    }
}
