@using UORespawnApp.Scripts
@using UORespawnApp.Scripts.Services
@using UORespawnApp.Scripts.Entities
@using UORespawnApp.Scripts.Utilities
@using UORespawnApp.Scripts.Constants
@using System.IO.Compression

@inject AccountService AccountService
@inject FtpCredentialService CredentialService
@inject FtpConnectionService ConnectionService
@inject FtpSyncService SyncService

<div class="card map-card mb-3">
    <div class="card-header text-center">
        <span class="text-primary" style="font-size: 1.25rem;">
            <span class="bi bi-hdd-network me-2"></span>UO Server Integration
        </span>
        <InfoIcon Text="Connect to your UO server for automatic file sync" />
    </div>
    <div class="card-body">

        <!-- Step 1: Server Type -->
        <div class="step-label text-muted small text-center mb-1">Server</div>
        <div class="d-flex justify-content-center mb-3">
            <button class="server-type-btn-single @(selectedServerType == "ServUO" ? "servuo" : "muo")"
                    @onclick="ToggleServerType">
                @if (selectedServerType == "ServUO")
                {
                    <img src="SERVUO.png" alt="ServUO" class="server-type-logo" />
                    <span class="server-type-label">ServUO</span>
                }
                else
                {
                    <img src="MUO.png" alt="MUO" class="server-type-logo" />
                    <span class="server-type-label">MUO</span>
                }
                <span class="server-type-switch-icon bi bi-arrow-left-right"></span>
            </button>
        </div>

        <!-- Step 2: Connection Mode -->
        <div class="step-label text-muted small text-center mb-1">Connection</div>
        <div class="d-flex justify-content-center mb-4">
            <div class="connection-type-toggle">
                <button class="toggle-btn @(connectionType == ConnectionType.Local ? "active-local" : "")"
                        @onclick="() => SetConnectionType(ConnectionType.Local)">
                    <span class="bi bi-pc-display me-2"></span>Local Server
                </button>
                <button class="toggle-btn @(connectionType == ConnectionType.Remote ? "active-remote" : "")"
                        @onclick="() => SetConnectionType(ConnectionType.Remote)">
                    <span class="bi bi-cloud me-2"></span>Remote Server
                </button>
            </div>
        </div>

        <!-- LOCAL LINK SECTION -->
        @if (connectionType == ConnectionType.Local)
        {
            <div class="text-center">
                @if (!DataWatcher.IsSupported)
                {
                    <div class="alert alert-warning mb-3">
                        <span class="bi bi-exclamation-triangle me-2"></span>
                        <strong>Not Supported on This Platform</strong>
                    </div>
                }

                @if (isLocalConfigured)
                {
                    <!-- LINKED STATE: paths + Unlink button -->
                    <div class="server-paths-display mb-3">
                        <div class="server-path-row">
                            <span class="bi bi-folder-fill me-1 text-info"></span>
                            <span class="path-label">Scripts:</span>
                            <span class="server-path">@Settings.ScriptsCustomFolder</span>
                        </div>
                        <div class="server-path-row mt-1">
                            <span class="bi bi-database-fill me-1 text-warning"></span>
                            <span class="path-label">Data:</span>
                            <span class="server-path">@Settings.ServerDataFolder</span>
                        </div>
                    </div>
                    <button class="btn btn-danger"
                            style="min-width: 180px;"
                            @onclick="UnlinkServer"
                            disabled="@(!DataWatcher.IsSupported)">
                        <span class="bi bi-x-circle me-2"></span>Unlink Server
                    </button>
                }
                else if (isLinkBroken)
                {
                    <!-- BROKEN LINK STATE: stored paths invalid, offer repair or clear -->
                    <div class="server-paths-display broken mb-3">
                        <div class="text-warning small mb-2">
                            <span class="bi bi-exclamation-triangle me-1"></span>
                            Stored paths not found — server may have moved
                        </div>
                        <div class="server-path-row">
                            <span class="bi bi-folder-fill me-1 text-danger"></span>
                            <span class="path-label">Scripts:</span>
                            <span class="server-path broken">@Settings.ScriptsCustomFolder</span>
                        </div>
                        <div class="server-path-row mt-1">
                            <span class="bi bi-database-fill me-1 text-danger"></span>
                            <span class="path-label">Data:</span>
                            <span class="server-path broken">@Settings.ServerDataFolder</span>
                        </div>
                    </div>
                    <button class="btn btn-warning"
                            style="min-width: 180px;"
                            @onclick="RepairOrUnlink"
                            disabled="@(!DataWatcher.IsSupported)">
                        <span class="bi bi-exclamation-triangle me-2"></span>Broken Link
                    </button>
                    <div class="text-muted small mt-2">
                        Click to attempt auto-repair, or clear and re-link.
                    </div>
                }
                else
                {
                    <!-- UNLINKED STATE: folder pickers + Install & Link button -->
                    <div class="folder-section">

                        <!-- Custom (Scripts) Folder -->
                        <div class="folder-picker-row">
                            <div class="folder-picker-header">
                                <span class="bi bi-folder-fill me-1 text-info"></span>
                                <strong>Custom Scripts Folder</strong>
                                <small class="text-muted ms-2">
                                    @if (selectedServerType == "ServUO")
                                    { <text>e.g. Scripts/Custom/</text> }
                                    else
                                    { <text>e.g. Projects/UOContent/Custom/</text> }
                                </small>
                            </div>
                            <div class="folder-picker-control mt-1">
                                @if (!string.IsNullOrEmpty(pendingCustomFolder))
                                {
                                    <span class="selected-path text-truncate">@pendingCustomFolder</span>
                                }
                                <button class="btn btn-sm btn-outline-info"
                                        @onclick="BrowseCustomFolder"
                                        disabled="@(!DataWatcher.IsSupported)">
                                    <span class="bi bi-folder2-open me-1"></span>Browse
                                </button>
                            </div>
                        </div>

                        <!-- Data Folder -->
                        <div class="folder-picker-row">
                            <div class="folder-picker-header">
                                <span class="bi bi-database-fill me-1 text-warning"></span>
                                <strong>Server Data Folder</strong>
                                <small class="text-muted ms-2">
                                    @if (selectedServerType == "ServUO")
                                    { <text>e.g. Data/</text> }
                                    else
                                    { <text>e.g. Distribution/Data/</text> }
                                </small>
                            </div>
                            <div class="folder-picker-control mt-1">
                                @if (!string.IsNullOrEmpty(pendingDataFolder))
                                {
                                    <span class="selected-path text-truncate">@pendingDataFolder</span>
                                }
                                <button class="btn btn-sm btn-outline-warning"
                                        @onclick="BrowseDataFolder"
                                        disabled="@(!DataWatcher.IsSupported)">
                                    <span class="bi bi-folder2-open me-1"></span>Browse
                                </button>
                            </div>
                        </div>

                    </div>

                    <!-- SPLIT BUTTON: Install (copies scripts) | Link (existing install only) -->
                    <div class="d-flex gap-3 justify-content-center flex-wrap mb-3">
                        <button class="btn btn-info"
                                style="min-width: 160px;"
                                @onclick="StartInstall"
                                disabled="@(!CanLink)">
                            <span class="bi bi-box-arrow-in-down me-2"></span>Install
                        </button>
                        <button class="btn btn-success"
                                style="min-width: 160px;"
                                @onclick="LinkOnly"
                                disabled="@(!CanLink)">
                            <span class="bi bi-link-45deg me-2"></span>Link
                        </button>
                    </div>

                    @if (showInstallWarning)
                    {
                        <div class="alert alert-warning mt-3 text-center" style="max-width: 500px; margin: 12px auto 0;">
                            <strong><span class="bi bi-exclamation-triangle me-1"></span>Replace Existing Scripts?</strong>
                            <p class="small mb-2 mt-1">Scripts already installed. Overwrite with v@Utility.Version?</p>
                            <div class="d-flex gap-2 justify-content-center">
                                <button class="btn btn-sm btn-secondary" @onclick="CancelInstall">Cancel</button>
                                <button class="btn btn-sm btn-warning" @onclick="ConfirmInstall">
                                    <span class="bi bi-arrow-repeat me-1"></span>Replace &amp; Install
                                </button>
                            </div>
                        </div>
                    }

                    }

                @if (!string.IsNullOrEmpty(localSetupMessage))
                {
                    <div class="alert @(localSetupSuccess ? "alert-success" : "alert-danger") mt-3">
                        @localSetupMessage
                    </div>
                }
            </div>
        }

        <!-- REMOTE SERVER SECTION (FTP Sync) -->
        @if (connectionType == ConnectionType.Remote)
        {
            @if (!AccountService.HasActiveAccount)
            {
                <div class="alert alert-warning mb-3 text-center">
                    <span class="bi bi-person-exclamation me-2"></span>
                    <strong>No Account Selected</strong>
                    <p class="mb-2 mt-2">
                        FTP features require an account setup. <strong>No password needed for the app!</strong>
                    </p>
                    <p class="mb-2 small text-muted">
                        Accounts are friendly labels that point to a folder where YOUR FTP credentials are stored securely.
                    </p>
                    <button class="btn btn-sm btn-warning" @onclick="ShowAccountModal">
                        <span class="bi bi-person-plus me-1"></span>Setup Account
                    </button>
                </div>
            }
            else
            {
                <!-- Account Info Bar -->
                <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-secondary">
                    <div>
                        <span class="bi bi-person-circle me-2 text-info"></span>
                        <strong>@AccountService.ActiveAccount?.Name</strong>
                        <small class="text-muted ms-2">
                            <span class="bi bi-folder2 me-1"></span>
                            @TruncatePath(AccountService.ActiveAccount?.CredentialFolderPath ?? "")
                        </small>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ShowAccountModal" title="Switch Account">
                        <span class="bi bi-arrow-repeat"></span>
                    </button>
                </div>

                @if (!hasCredentials)
                {
                    <div class="alert alert-info mb-3 small">
                        <span class="bi bi-info-circle me-2"></span>
                        No FTP credentials configured. Fill in the details below to enable sync.
                    </div>
                }

                <!-- FTP Configuration Form -->
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label text-muted small">Host</label>
                        <input type="text"
                               class="form-control form-control-sm bg-secondary text-light border-dark"
                               placeholder="ftp.yourserver.com"
                               @bind="credentials.Host" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label text-muted small">Port</label>
                        <input type="number"
                               class="form-control form-control-sm bg-secondary text-light border-dark"
                               @bind="credentials.Port" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label text-muted small">Username</label>
                        <input type="text"
                               class="form-control form-control-sm bg-secondary text-light border-dark"
                               placeholder="ftpuser"
                               @bind="credentials.Username" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">Password</label>
                        <div class="input-group input-group-sm">
                            <input type="@(showPassword ? "text" : "password")"
                                   class="form-control bg-secondary text-light border-dark"
                                   placeholder="••••••••"
                                   @bind="credentials.Password" />
                            <button class="btn btn-outline-secondary" type="button" @onclick="TogglePassword">
                                <span class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></span>
                            </button>
                        </div>
                    </div>

                    <!-- Remote Custom Scripts Path -->
                    <div class="col-12">
                        <label class="form-label text-muted small">
                            <span class="bi bi-folder-fill me-1 text-info"></span>Remote Custom Scripts Path
                        </label>
                        <input type="text"
                               class="form-control form-control-sm bg-secondary text-light border-dark"
                               placeholder="@RemoteCustomPathPlaceholder"
                               @bind="credentials.RemoteCustomPath" />
                        <div class="form-text text-muted small">
                            @if (selectedServerType == "ServUO")
                            {
                                <text>Remote path to your server's <code>Scripts/Custom/</code> folder.</text>
                            }
                            else
                            {

                                <text>Remote path to your server's <code>Projects/UOContent/Custom/</code> folder.</text>
                            }
                        </div>
                    </div>

                    <!-- Remote Data Exchange Path -->
                    <div class="col-12">
                        <label class="form-label text-muted small">
                            <span class="bi bi-database-fill me-1 text-warning"></span>Remote Data Exchange Path
                        </label>
                        <input type="text"
                               class="form-control form-control-sm bg-secondary text-light border-dark"
                               placeholder="@RemoteDataPathPlaceholder"
                               @bind="credentials.RemotePath" />
                        <div class="form-text text-muted small">
                            @if (selectedServerType == "ServUO")
                            {
                                <text>Remote path to your server's <code>Data/</code> folder.</text>
                            }
                            else
                            {

                                <text>Remote path to your server's <code>Distribution/Data/</code> folder.</text>
                            }
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="credentials.UseTls" id="ftpTls">
                            <label class="form-check-label small" for="ftpTls">
                                <span class="bi bi-shield-lock me-1"></span>Use TLS/SSL
                            </label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" @bind="credentials.UsePassiveMode" id="ftpPassive">
                            <label class="form-check-label small" for="ftpPassive">
                                <span class="bi bi-arrow-down-up me-1"></span>Passive Mode
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Validation Errors -->
                @if (credentials.ValidationErrors.Count > 0 && hasAttemptedSave)
                {
                    <div class="alert alert-warning mt-3 mb-0 py-2">
                        <small>
                            @foreach (var error in credentials.ValidationErrors)
                            {
                                <span class="bi bi-exclamation-triangle me-1"></span>
                                @error
                            }
                        </small>
                    </div>
                }

                <!-- Status Messages -->
                @if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="alert @statusAlertClass mt-3 mb-0 py-2">
                        <span class="bi @statusIcon me-2"></span>@statusMessage
                    </div>
                }

                <!-- Action Buttons -->
                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-secondary">
                    <div>
                        @if (hasCredentials)
                        {
                            <button class="btn btn-sm btn-outline-danger" @onclick="DeleteCredentials" disabled="@isBusy">
                                <span class="bi bi-trash me-1"></span>Delete
                            </button>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-info" @onclick="TestConnection" disabled="@isBusy">
                            @if (isTesting)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                                <text>Testing...</text>
                            }
                            else
                            {
                                <span class="bi bi-plug me-1"></span>
                                <text>Test</text>
                            }
                        </button>
                        <button class="btn btn-sm btn-success" @onclick="SaveCredentials" disabled="@isBusy">
                            <span class="bi bi-floppy me-1"></span>Save
                        </button>
                    </div>
                </div>

                <!-- Sync Operations -->
                @if (hasCredentials && credentials.IsConfigured)
                {
                    <div class="mt-3 pt-3 border-top border-secondary">
                        <div class="text-muted small mb-2 text-center">
                            <span class="bi bi-arrow-repeat me-1"></span>Sync Operations
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-sm btn-outline-success flex-fill" @onclick="UploadSpawnData" disabled="@isSyncing">
                                @if (isSyncing && syncOperation == "upload")
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <span class="bi bi-cloud-arrow-up me-1"></span>
                                }
                                Push Spawns
                            </button>
                            <button class="btn btn-sm btn-outline-info flex-fill" @onclick="DownloadReferenceData" disabled="@isSyncing">
                                @if (isSyncing && syncOperation == "download")
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                else
                                {
                                    <span class="bi bi-cloud-arrow-down me-1"></span>
                                }
                                Pull References
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(syncMessage))
                        {
                            <div class="alert @syncAlertClass mt-2 mb-0 py-2 small">
                                <span class="bi @syncIcon me-1"></span>@syncMessage
                            </div>
                        }
                    </div>
                }
            }
        }

        <!-- MANUAL TRANSFER SECTION -->
        <div class="manual-section mt-3">
            <button class="manual-section-header" @onclick="() => showManualTransfer = !showManualTransfer">
                <span class="bi bi-folder-symlink me-2 text-warning"></span>
                Manual Transfer
                <span class="bi @(showManualTransfer ? "bi-chevron-up" : "bi-chevron-down") ms-auto"></span>
            </button>
            @if (showManualTransfer)
            {
                <div class="manual-section-body">
                    <div class="text-center">
                        <p class="text-muted small mb-3">
                            Export scripts and data files, then manually transfer them to your server.
                        </p>

                        <!-- Export Server Scripts -->
                        <div class="mb-3">
                            <button class="btn btn-info w-100" style="max-width: 350px;" @onclick="ExportServerScripts" disabled="@isExporting">
                                @if (isExporting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <text>Exporting...</text>
                                }
                                else
                                {
                                    <span class="bi bi-file-earmark-zip me-2"></span>
                                    <text>Export Server Scripts (.zip)</text>
                                }
                            </button>
                            <small class="text-muted d-block mt-1">
                                Extract to: <code>
                                    @if (selectedServerType == "ServUO")
                                    { <text>Scripts/Custom/UORespawnServer/</text> }
                                    else
                                    { <text>Projects/UOContent/Custom/UORespawnServer/</text> }
                                </code>
                            </small>
                        </div>

                        <!-- Export Data Pack -->
                        <SpawnPackExportCard />

                        @if (!string.IsNullOrEmpty(exportMessage))
                        {
                            <div class="alert @(exportSuccess ? "alert-success" : "alert-danger") small mt-3">
                                @exportMessage
                            </div>
                        }

                        <!-- Help Section -->
                        <div class="alert alert-secondary mt-3 text-start small">
                            <strong><span class="bi bi-question-circle me-1"></span>Manual Setup Steps:</strong>
                            <ol class="mb-0 mt-2 ps-3">
                                <li>Export and extract <strong>Server Scripts</strong> to your server's <code>Custom/</code> folder</li>
                                <li>Start your server once — it will create the <code>UORespawn/</code> folder under Data</li>
                                <li>Copy reference files from server's <code>OUTPUT/</code> to editor's <code>Data/UOR_DATA/</code></li>
                                <li>Configure spawns in the editor</li>
                                <li>Export and copy spawn data to server's <code>INPUT/</code> folder</li>
                                <li>Restart your server to load the spawns</li>
                            </ol>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnShowAccountModal { get; set; }

    // Connection type selection
    private enum ConnectionType { Local, Remote }

    private ConnectionType connectionType = ConnectionType.Local;

    // Local link state
    private bool isLocalConfigured => ServerSetupUtility.IsServerConfigured();
    private bool isLinkBroken => ServerSetupUtility.IsLinkBroken();
    private string pendingCustomFolder = "";
    private string pendingDataFolder = "";
    private string selectedServerType = Settings.ServerType.Length > 0 ? Settings.ServerType : "ServUO";
    private bool CanLink => !string.IsNullOrEmpty(pendingCustomFolder) && !string.IsNullOrEmpty(pendingDataFolder);
    private string localSetupMessage = "";
    private bool localSetupSuccess = false;
    private bool showInstallWarning = false;
    private bool showManualTransfer = false;

    private string RemoteCustomPathPlaceholder => selectedServerType == "MUO"
        ? "e.g. /Projects/UOContent/Custom/"
        : "e.g. /Scripts/Custom/";

    private string RemoteDataPathPlaceholder => selectedServerType == "MUO"
        ? "e.g. /Distribution/Data/"
        : "e.g. /Data/";

    // FTP state
    private FtpCredentials credentials = new();
    private bool hasCredentials = false;
    private bool showPassword = false;
    private bool isBusy = false;
    private bool isTesting = false;
    private bool hasAttemptedSave = false;
    private string statusMessage = "";
    private string statusAlertClass = "alert-info";
    private string statusIcon = "bi-info-circle";

    // Sync state
    private bool isSyncing = false;
    private string syncOperation = "";
    private string syncMessage = "";
    private string syncAlertClass = "alert-info";
    private string syncIcon = "bi-info-circle";
    private bool isLoadingCredentials = false;

    // Manual export state
    private bool isExporting = false;
    private string exportMessage = "";
    private bool exportSuccess = false;

    protected override void OnInitialized()
    {
        // Determine initial connection type based on current configuration
        if (isLocalConfigured || isLinkBroken)
        {
            connectionType = ConnectionType.Local;
        }
        else if (AccountService.HasActiveAccount)
        {
            connectionType = ConnectionType.Remote;
        }

        LoadCredentialsInternal();
        CredentialService.CredentialsChanged += OnCredentialsChanged;
        AccountService.ActiveAccountChanged += OnAccountChanged;
    }

    private void SetConnectionType(ConnectionType type)
    {
        connectionType = type;
        // Clear messages when switching
        localSetupMessage = "";
        statusMessage = "";
        exportMessage = "";
        syncMessage = "";
    }

    private void ToggleServerType()
    {
        selectedServerType = selectedServerType == "ServUO" ? "MUO" : "ServUO";
    }

    // ==================== LOCAL LINK METHODS ====================

    private async Task BrowseCustomFolder()
    {
        try
        {
#if WINDOWS
            var folderPicker = new Windows.Storage.Pickers.FolderPicker();
            var window = (Application.Current?.Windows[0]?.Handler?.PlatformView as Microsoft.UI.Xaml.Window);
            if (window != null)
            {
                var hwnd = WinRT.Interop.WindowNative.GetWindowHandle(window);
                WinRT.Interop.InitializeWithWindow.Initialize(folderPicker, hwnd);
            }

            folderPicker.SuggestedStartLocation = Windows.Storage.Pickers.PickerLocationId.ComputerFolder;
            folderPicker.FileTypeFilter.Add("*");

            var folder = await folderPicker.PickSingleFolderAsync();
            if (folder != null)
            {
                var validation = ServerSetupUtility.ValidateCustomFolder(folder.Path);
                if (validation.IsValid)
                {
                    pendingCustomFolder = folder.Path;
                    localSetupMessage = "";
                }
                else
                {
                    localSetupMessage = $"✗ {validation.Message}";
                    localSetupSuccess = false;
                }
                StateHasChanged();
            }
#else
            localSetupMessage = "✗ Folder picker not available on this platform.";
            localSetupSuccess = false;
            await Task.CompletedTask;
#endif
        }
        catch (Exception ex)
        {
            localSetupMessage = $"✗ Error: {ex.Message}";
            localSetupSuccess = false;
            Logger.Error("Error browsing Custom folder", ex);
            StateHasChanged();
        }
    }

    private async Task BrowseDataFolder()
    {
        try
        {
#if WINDOWS
            var folderPicker = new Windows.Storage.Pickers.FolderPicker();
            var window = (Application.Current?.Windows[0]?.Handler?.PlatformView as Microsoft.UI.Xaml.Window);
            if (window != null)
            {
                var hwnd = WinRT.Interop.WindowNative.GetWindowHandle(window);
                WinRT.Interop.InitializeWithWindow.Initialize(folderPicker, hwnd);
            }

            folderPicker.SuggestedStartLocation = Windows.Storage.Pickers.PickerLocationId.ComputerFolder;
            folderPicker.FileTypeFilter.Add("*");

            var folder = await folderPicker.PickSingleFolderAsync();
            if (folder != null)
            {
                var validation = ServerSetupUtility.ValidateDataFolder(folder.Path);
                if (validation.IsValid)
                {
                    pendingDataFolder = folder.Path;
                    localSetupMessage = "";
                }
                else
                {
                    localSetupMessage = $"✗ {validation.Message}";
                    localSetupSuccess = false;
                }
                StateHasChanged();
            }
#else
            localSetupMessage = "✗ Folder picker not available on this platform.";
            localSetupSuccess = false;
            await Task.CompletedTask;
#endif
        }
        catch (Exception ex)
        {
            localSetupMessage = $"✗ Error: {ex.Message}";
            localSetupSuccess = false;
            Logger.Error("Error browsing Data folder", ex);
            StateHasChanged();
        }
    }

    private void StartInstall()
    {
        if (!CanLink) return;

        var installStatus = ServerSetupUtility.CheckInstallation(pendingCustomFolder, pendingDataFolder);
        if (installStatus.IsInstalled)
        {
            showInstallWarning = true;
            localSetupMessage = "";
        }
        else
        {
            PerformInstall(forceReinstall: false);
        }
    }

    private void PerformInstall(bool forceReinstall)
    {
        try
        {
            showInstallWarning = false;

            var serverType = selectedServerType == "MUO"
                ? ServerSetupUtility.ServerType.MUO
                : ServerSetupUtility.ServerType.ServUO;

            var (success, message) = ServerSetupUtility.FullServerSetup(
                pendingCustomFolder, pendingDataFolder, serverType, forceReinstall);

            if (success)
            {
                Settings.ScriptsCustomFolder = pendingCustomFolder;
                Settings.ServerDataFolder = pendingDataFolder;
                Settings.ServerType = selectedServerType;

                localSetupMessage = "✓ Scripts installed.";
                localSetupSuccess = true;

                pendingCustomFolder = "";
                pendingDataFolder = "";

                Logger.Info($"Server installed: Custom={Settings.ScriptsCustomFolder} | Data={Settings.ServerDataFolder}");
            }
            else
            {
                localSetupMessage = $"✗ {message}";
                localSetupSuccess = false;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            localSetupMessage = $"✗ Error: {ex.Message}";
            localSetupSuccess = false;
            Logger.Error("Error during install", ex);
            StateHasChanged();
        }
    }

    private void ConfirmInstall() => PerformInstall(forceReinstall: true);

    private void CancelInstall()
    {
        showInstallWarning = false;
        localSetupMessage = "";
        StateHasChanged();
    }

    private void LinkOnly()
