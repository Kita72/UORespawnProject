    private void RepairOrUnlink()
    {
        try
        {
            if (ServerSetupUtility.TryRepairLink())
            {
                localSetupMessage = "✓ Link repaired automatically.";
                localSetupSuccess = true;
            }
            else
            {
                ServerSetupUtility.UnlinkServer();
                localSetupMessage = "Link cleared — please re-select your server folders.";
                localSetupSuccess = false;
